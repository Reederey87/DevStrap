# P5-QUAL-02: `devstrap run-loop --once` (XP-02) runs a single scan+sync+
# materialize cycle through the real binary and exits 0, exercising the
# previously-untested run-loop path.
# P6-XP-03: the tick now runs a scan+adopt stage first; it adopts a repo that
# appears in the tree, and a second --once over the unchanged tree does NOT
# re-adopt it (idempotent — no duplicate project.added event).

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# A valid bare remote with one commit on main (for the `add` skeleton path).
exec git init --bare -b main $WORK/remote.git
exec git clone $WORK/remote.git $WORK/src
exec sh -c 'echo hello > $WORK/src/README.md'
exec sh -c 'cd $WORK/src && git add README.md && git commit -m init && git branch -M main && git push origin main'

# A second remote, checked out directly inside the managed tree so the loop's
# scan stage (not `add`) discovers and adopts it (P6-XP-03).
exec git init --bare -b main $WORK/remote2.git
exec git clone $WORK/remote2.git $WORK/src2
exec sh -c 'echo hi > $WORK/src2/README.md'
exec sh -c 'cd $WORK/src2 && git add README.md && git commit -m init && git branch -M main && git push origin main'

exec devstrap --home=$WORK/home --root=$WORK/Code init
exec devstrap --home=$WORK/home --root=$WORK/Code add --path work/proj $WORK/remote.git

# A real checkout present in the tree but never `add`ed — only the scan stage
# can bring it into the namespace.
exec git clone $WORK/remote2.git $WORK/Code/work/checkout

# First run-loop tick: the scan stage adopts work/checkout, then sync pushes the
# local events and materializes; exits 0.
exec devstrap --home=$WORK/home --root=$WORK/Code run-loop --once --hub-file=$WORK/hub.json
stdout 'materialized'
# The tick header names all three stages and goes to stderr (P5-CLI-05).
stderr 'run-loop tick: scan \+ sync \+ materialize'
# The scan stage adopted the previously-unknown checkout exactly once.
stderr 'scan adopted 1 new project'

exec sh -c 'test -d $WORK/Code/work/proj/.git'

# Second run-loop tick over the now-unchanged tree: the scan stage is idempotent
# — nothing new is adopted, so no "scan adopted" line is printed.
exec devstrap --home=$WORK/home --root=$WORK/Code run-loop --once --hub-file=$WORK/hub.json
stderr 'run-loop tick: scan \+ sync \+ materialize'
! stderr 'scan adopted'
