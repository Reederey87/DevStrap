# P7-WIP-03: `wip status`/`wip show` are the read/inspect half of the
# working-state validation plane Layer B (spec/07). status renders every
# device's pending WIP recovery ref from the local device_wip mirror; show
# fetches and displays one device's ref content (a stat summary + full diff)
# WITHOUT applying anything to the working tree or index. Zero pending WIP is
# the normal, healthy case and gets a plain informational line, never a
# warning; multiple candidates with no --device is a usage error naming the
# candidates rather than a silent guess.

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# Bare remote with one commit, shared by both devices.
exec git init --bare -b main $WORK/remote.git
exec git clone $WORK/remote.git $WORK/src
exec sh -c 'echo hello > $WORK/src/README.md'
exec sh -c 'cd $WORK/src && git add README.md && git commit -m init && git branch -M main && git push origin main'

# Device A: init, add the project, sync (materializes a real clone).
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/proj $WORK/remote.git
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'pushed 1'

# `wip status`/`wip show` on a project with zero pending WIP: a plain
# informational line, never a warning.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA wip status work/proj
stdout 'No pending WIP for work/proj'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA wip show work/proj
stdout 'No pending WIP for work/proj'

# Device A: make an uncommitted change and push its WIP ref (mirrors A's own
# push into device_wip immediately — see wip.go's UpsertDeviceWipTx comment).
exec sh -c 'echo A_MARKER >> $WORK/CodeA/work/proj/README.md'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA wip push work/proj

# `wip status` now shows exactly one pending row for A's own device.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA wip status work/proj
stdout 'Device\tRef\tSHA\tBase\tObserved'
stdout 'refs/devstrap/wip/'
stdout 'captured'

# `wip show` with a single unambiguous candidate needs no --device, and shows
# the stat summary + full diff of what changed (A's marker), without touching
# the working tree — the marker stays uncommitted-but-present exactly as
# `wip push` (stash create) left it; only `wip show`'s own read-only-ness is
# under test here, so compare the file byte-for-byte before and after.
exec cp $WORK/CodeA/work/proj/README.md $WORK/readme-before-show.txt
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA wip show work/proj
stdout 'README.md'
stdout '\+A_MARKER'
! stdout 'diff --cc'
exec cmp $WORK/readme-before-show.txt $WORK/CodeA/work/proj/README.md

# Device B: init, enroll+approve (so it can decrypt A's events), sync
# (materializes its own clone of the same project). B must be enrolled under
# its OWN real device id (captured via `devices list`, the established
# multi-device idiom — see env_exchange.txtar/sync_trust_propagation.txtar) —
# NOT an arbitrary chosen label: events are signed with the device's own
# self-generated id, so an id mismatch between the enrolled row and B's real
# id would make every event B ever authors permanently fail signature
# verification on A (a device row exists, but under the wrong id).
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB init
exec sh -c 'devstrap --home=$WORK/homeB --root=$WORK/CodeB devices list | awk "NR==1{print \$1}" > $WORK/dev-b-id.txt'
exec sh -c 'test -s $WORK/dev-b-id.txt'
exec sh -c 'B_ID=$(cat $WORK/dev-b-id.txt); REC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); SIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); FP=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --fingerprint); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$B_ID" --name b --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve --fingerprint "$FP"'
stdout 'enrolled as approved'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
stdout 'materialized'

# Device B: make its own uncommitted change and push its own WIP ref, then
# publish it so A's mirror learns about it too.
exec sh -c 'echo B_MARKER >> $WORK/CodeB/work/proj/README.md'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB wip push work/proj
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
stdout 'pushed 1'
# A still has its own earlier (step 6) wip-pushed event queued alongside the
# device-enroll event, both flushed in one push at the "materializes" sync
# above — so this final pull count is not pinned to a fixed number here; the
# `wip status` assertion right below is what actually proves A learned about
# B's pending WIP.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json

# A's mirror now knows about two devices' pending WIP for the same project.
exec sh -c 'devstrap --home=$WORK/homeA --root=$WORK/CodeA wip status work/proj > $WORK/status-a.txt'
exec sh -c 'grep -qf $WORK/dev-b-id.txt $WORK/status-a.txt'

# `wip show` with no --device and multiple candidates is a usage error naming
# the candidates, never a silent guess.
exec sh -c '! devstrap --home=$WORK/homeA --root=$WORK/CodeA wip show work/proj 2> $WORK/show-multi.err'
exec sh -c 'grep -q "multiple devices have pending WIP for work/proj" $WORK/show-multi.err'
exec sh -c 'grep -qf $WORK/dev-b-id.txt $WORK/show-multi.err'
exec sh -c 'grep -q -- --device $WORK/show-multi.err'

# `wip show --device <B's real id>` unambiguously resolves to B's ref and content.
exec sh -c 'devstrap --home=$WORK/homeA --root=$WORK/CodeA wip show work/proj --device "$(cat $WORK/dev-b-id.txt)"'
stdout '\+B_MARKER'
! stdout '\+A_MARKER'

# `wip show --device <unknown>` is a clear usage error, not a crash.
! exec devstrap --home=$WORK/homeA --root=$WORK/CodeA wip show work/proj --device nope
stderr 'no pending WIP for device nope'
