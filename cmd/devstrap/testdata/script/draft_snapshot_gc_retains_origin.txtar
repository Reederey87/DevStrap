# P6-DATA-01: the origin that creates a draft snapshot must record its own
# draft_snapshots row, otherwise hub/local GC can delete the only encrypted
# draft blob before the event ever re-applies locally.

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

exec devstrap --home=$WORK/home --root=$WORK/Code init

# A no-remote git repo is adopted as local_git, which uses draft snapshots for
# content sync.
exec git init -b main $WORK/Code/work/local
exec sh -c 'echo hi > $WORK/Code/work/local/note.txt'
exec devstrap --home=$WORK/home --root=$WORK/Code scan --adopt

exec sh -c 'devstrap --home=$WORK/home --root=$WORK/Code draft snapshot create work/local > $WORK/create.out'
exec grep 'Created draft snapshot' $WORK/create.out
exec grep 'age_blob:' $WORK/create.out

exec devstrap --home=$WORK/home --root=$WORK/Code sync --hub-file=$WORK/hub.json
exec sh -c 'HASH=$(sed -n "s/.*age_blob:\\([0-9a-f][0-9a-f]*\\).*/\\1/p" $WORK/create.out); test -f $WORK/home/blobs/$HASH.age'
exec sh -c 'HASH=$(sed -n "s/.*age_blob:\\([0-9a-f][0-9a-f]*\\).*/\\1/p" $WORK/create.out); test -f $WORK/hub-blobs/$HASH.blob'

# --grace-window=0 so retention is proven by the draft_snapshots reference
# (P6-DATA-01), not by the blob merely being younger than the default window.
exec devstrap --home=$WORK/home --root=$WORK/Code hub gc --hub-file=$WORK/hub.json --grace-window=0
stdout 'deleted 0 unreferenced hub blob'
exec sh -c 'HASH=$(sed -n "s/.*age_blob:\\([0-9a-f][0-9a-f]*\\).*/\\1/p" $WORK/create.out); test -f $WORK/home/blobs/$HASH.age'
exec sh -c 'HASH=$(sed -n "s/.*age_blob:\\([0-9a-f][0-9a-f]*\\).*/\\1/p" $WORK/create.out); test -f $WORK/hub-blobs/$HASH.blob'

exec devstrap --home=$WORK/home --root=$WORK/Code conflicts list
stdout 'No open conflicts.'
