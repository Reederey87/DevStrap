# P6-HUB-01: `hub gc` must never sweep from a stale local replica. Device B
# creates a draft snapshot and syncs it to the hub; device A — which has NOT
# synced since — runs `hub gc`. The pre-GC pull applies B's event, so B's live
# draft blob enters A's mark set and survives the sweep even with
# --grace-window=0 (before the fix, A's stale RetainedBlobRefs deleted it).

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# Device A (founder): init and found the workspace on the empty hub.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json

# Device B (joiner): init --join, then sync to observe the populated hub.
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB init --join

# Enroll + approve B on A under B's real device id, then publish the grant.
exec sh -c 'B_ID=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices list | awk "NR==1{print \$1}"); REC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); SIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); FP=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --fingerprint); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$B_ID" --name b --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve --fingerprint "$FP"'
stdout 'enrolled as approved'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json

# B ingests its grant, then creates a draft project snapshot and syncs it: the
# encrypted bundle blob and its draft.snapshot.created event land on the hub.
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json

# Mirror enrollment: B approves A so A's recipient is in the bundle encryption
# set (recipient sets are per-store trust; without this A could retain but not
# decrypt B's draft).
exec sh -c 'A_ID=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices list | awk "\$2==\"local\"{print \$1}"); REC=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient); SIG=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --signing); FP=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --fingerprint); devstrap --home=$WORK/homeB --root=$WORK/CodeB devices enroll "$A_ID" --name a --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve --fingerprint "$FP"'
stdout 'enrolled as approved'
exec git init -b main $WORK/CodeB/work/b-draft
exec sh -c 'echo b-secret-notes > $WORK/CodeB/work/b-draft/note.txt'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB scan --adopt
exec sh -c 'devstrap --home=$WORK/homeB --root=$WORK/CodeB draft snapshot create work/b-draft > $WORK/create.out'
exec grep 'age_blob:' $WORK/create.out
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec sh -c 'HASH=$(sed -n "s/.*age_blob:\\([0-9a-f][0-9a-f]*\\).*/\\1/p" $WORK/create.out); test -f $WORK/hub-blobs/$HASH.blob'

# A runs hub gc WITHOUT syncing first. Its local replica has never seen B's
# snapshot event; the pre-GC pull must apply it so B's blob is retained.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA hub gc --hub-file=$WORK/hub.json --grace-window=0
stdout 'deleted 0 unreferenced hub blob'
exec sh -c 'HASH=$(sed -n "s/.*age_blob:\\([0-9a-f][0-9a-f]*\\).*/\\1/p" $WORK/create.out); test -f $WORK/hub-blobs/$HASH.blob'

# A's gc pre-pull consumed B's event, so gc itself must have cached the blob
# (like sync does) — A's next sync can then extract B's draft even though the
# cursor has moved past the event. Pins the gc blob-fetch fix (review finding).
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec sh -c 'test -f $WORK/CodeA/work/b-draft/note.txt'
exec grep b-secret-notes $WORK/CodeA/work/b-draft/note.txt
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA conflicts list
stdout 'No open conflicts.'
