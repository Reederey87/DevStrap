# QUAL-03: `devstrap materialize` exits non-zero when any project fails, while
# still completing the batch — a sibling project that clones successfully is
# materialized. This keeps CI/cron gates and `devstrap materialize && ...`
# chains honest about partial failure.

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# A valid bare remote (HEAD on main) with one commit.
exec git init --bare -b main $WORK/remote.git
exec git clone $WORK/remote.git $WORK/src
exec sh -c 'echo hello > $WORK/src/README.md'
exec sh -c 'cd $WORK/src && git add README.md && git commit -m init && git branch -M main && git push origin main'

exec devstrap --home=$WORK/home --root=$WORK/Code init
# A valid project (will materialize) and a missing-remote project (will fail).
exec devstrap --home=$WORK/home --root=$WORK/Code add --path work/ok $WORK/remote.git
exec devstrap --home=$WORK/home --root=$WORK/Code add --path work/bad $WORK/missing.git

# materialize completes the batch but exits non-zero because work/bad failed.
! exec devstrap --home=$WORK/home --root=$WORK/Code materialize
stdout 'Materialized 1/2 projects'
stdout 'failed'

# The valid project was still materialized despite the sibling failure.
exec sh -c 'test -d $WORK/Code/work/ok/.git'
exec sh -c 'cat $WORK/Code/work/ok/README.md'
stdout 'hello'
