# P6-SEC-03: a device that never receives a key grant for a rotated epoch must
# not wedge forever. Cast: A founds; B is approved by A; C is approved by B —
# so when a revoke on A rotates to epoch 2, A grants only ITS known approved
# devices (B), and C (unknown to A — the device registry is per-device) is
# never granted epoch 2. Pre-fix, C's pull truncated at the first epoch-2
# event forever. Now: past the grace window (0s here) the event quarantines,
# the cursor advances (sync unwedged), doctor names the missing grant, the
# approve contiguity guard stops C from propagating its gap (unless
# --allow-epoch-gap), and a re-approve from B (which holds epochs 1+2)
# recovers the quarantined event via the replay path.

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# Bare remotes for the founder's two projects.
exec git init --bare -b main $WORK/remoteA.git
exec git clone $WORK/remoteA.git $WORK/srcA
exec sh -c 'echo hello-a > $WORK/srcA/README.md'
exec sh -c 'cd $WORK/srcA && git add README.md && git commit -m init && git branch -M main && git push origin main'
exec git init --bare -b main $WORK/remoteA2.git
exec git clone $WORK/remoteA2.git $WORK/srcA2
exec sh -c 'echo hello-a2 > $WORK/srcA2/README.md'
exec sh -c 'cd $WORK/srcA2 && git add README.md && git commit -m init && git branch -M main && git push origin main'

# Device A (founder): init, add a project, first sync founds epoch 1.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/a-proj $WORK/remoteA.git
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'pushed 1'

# Device B: join, pin A, get approved by A, sync both ways -> B holds epoch 1.
exec sh -c 'WS=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --workspace-id); devstrap --home=$WORK/homeB --root=$WORK/CodeB init --join --workspace-id "$WS"'
exec sh -c 'A_ID=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices list | awk "NR==1{print \$1}"); AREC=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient); ASIG=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --signing); AFP=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --fingerprint); devstrap --home=$WORK/homeB --root=$WORK/CodeB devices enroll "$A_ID" --name a --os linux --arch arm64 --age-recipient "$AREC" --signing-public-key "$ASIG" --approve --fingerprint "$AFP"'
exec sh -c 'B_ID=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices list | awk "NR==1{print \$1}"); REC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); SIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); BFP=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --fingerprint); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$B_ID" --name b --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve --fingerprint "$BFP"'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json

# Device C: join, pin BOTH existing devices (fleets >2 pin every device), get
# approved by B (NOT A — A never learns C exists), sync -> C holds epoch 1.
exec sh -c 'WS=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --workspace-id); devstrap --home=$WORK/homeC --root=$WORK/CodeC init --join --workspace-id "$WS"'
exec sh -c 'A_ID=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices list | awk "NR==1{print \$1}"); AREC=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient); ASIG=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --signing); AFP=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --fingerprint); devstrap --home=$WORK/homeC --root=$WORK/CodeC devices enroll "$A_ID" --name a --os linux --arch arm64 --age-recipient "$AREC" --signing-public-key "$ASIG" --approve --fingerprint "$AFP"'
exec sh -c 'B_ID=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices list | awk "NR==1{print \$1}"); BREC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); BSIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); BFP=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --fingerprint); devstrap --home=$WORK/homeC --root=$WORK/CodeC devices enroll "$B_ID" --name b --os linux --arch arm64 --age-recipient "$BREC" --signing-public-key "$BSIG" --approve --fingerprint "$BFP"'
exec sh -c 'C_ID=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices list | awk "NR==1{print \$1}"); CREC=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices recipient); CSIG=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices recipient --signing); CFP=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices recipient --fingerprint); devstrap --home=$WORK/homeB --root=$WORK/CodeB devices enroll "$C_ID" --name c --os linux --arch arm64 --age-recipient "$CREC" --signing-public-key "$CSIG" --approve --fingerprint "$CFP"'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC sync --hub-file=$WORK/hub.json
exec sh -c 'test -d $WORK/CodeC/work/a-proj/.git'

# Throwaway device D: enrolled+approved on A with real keys, then revoked.
# The revoke rotates the workspace key to epoch 2 and grants it to A's known
# approved devices only — B, never C.
exec devstrap --home=$WORK/homeD --root=$WORK/CodeD init
exec sh -c 'D_ID=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices list | awk "NR==1{print \$1}"); DREC=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient); DSIG=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient --signing); DFP=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient --fingerprint); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$D_ID" --name d --os linux --arch arm64 --age-recipient "$DREC" --signing-public-key "$DSIG" --approve --fingerprint "$DFP"'
exec sh -c 'D_ID=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices list | awk "NR==1{print \$1}"); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices revoke "$D_ID"'
stderr 'Rotated workspace key to epoch 2'

# A seals a new project under epoch 2 and pushes it (plus B's epoch-2 grant).
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/a2-proj $WORK/remoteA2.git
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json

# B converges normally (its grant rode the same push).
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec sh -c 'test -d $WORK/CodeB/work/a2-proj/.git'

# C, with the grace window forced to zero, hits the never-granted epoch: the
# event QUARANTINES instead of truncating forever — sync exits 0 and the
# cursor advances (the P6-SEC-03 un-wedge).
env DEVSTRAP_SYNC_KEY_GRANT_GRACE=0s
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC conflicts list
stdout '1 open conflict'
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC doctor
stdout 'awaiting key grants'
stdout 'epoch 2'

# The contiguity guard: C must not propagate its gap by approving new devices
# while it knows it is missing epoch 2 — unless explicitly overridden.
! exec sh -c 'DREC=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient); DSIG=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient --signing); DFP=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient --fingerprint); devstrap --home=$WORK/homeC --root=$WORK/CodeC devices enroll dev_e --name e --os linux --arch arm64 --age-recipient "$DREC" --signing-public-key "$DSIG" --approve --fingerprint "$DFP"'
stderr 'awaiting key grant'
stderr 'allow-epoch-gap'
exec sh -c 'DREC=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient); DSIG=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient --signing); DFP=$(devstrap --home=$WORK/homeD --root=$WORK/CodeD devices recipient --fingerprint); devstrap --home=$WORK/homeC --root=$WORK/CodeC devices enroll dev_e --name e --os linux --arch arm64 --age-recipient "$DREC" --signing-public-key "$DSIG" --approve --allow-epoch-gap --fingerprint "$DFP"'
stdout 'enrolled as approved'

# Recovery: B (holding epochs 1+2) re-approves C, granting every held epoch;
# after B pushes and C pulls, the quarantined epoch-2 event replays, the
# conflict auto-resolves, and a2-proj materializes on C.
exec sh -c 'C_ID=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices list | awk "NR==1{print \$1}"); CFP=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices recipient --fingerprint); devstrap --home=$WORK/homeB --root=$WORK/CodeB devices approve "$C_ID" --fingerprint "$CFP"'
stderr 'Granted 2 workspace key epoch'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC sync --hub-file=$WORK/hub.json
exec sh -c 'test -d $WORK/CodeC/work/a2-proj/.git'
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC conflicts list
stdout 'No open conflicts.'
