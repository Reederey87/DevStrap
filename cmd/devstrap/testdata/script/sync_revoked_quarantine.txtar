# P6-SYNC-01: a revoked device's signed event must be quarantined per event,
# not abort the whole sync batch or wedge the cursor. Device A knows B is
# approved and C is revoked; B and C both push project events; A syncs and must
# apply B's valid event while recording C's verification failure as a conflict.

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# Set up distinct bare git remotes so each synced project has a unique remote.
exec git init --bare -b main $WORK/remote-a.git
exec git clone $WORK/remote-a.git $WORK/src-a
exec sh -c 'echo a > $WORK/src-a/README.md'
exec sh -c 'cd $WORK/src-a && git add README.md && git commit -m init && git branch -M main && git push origin main'

exec git init --bare -b main $WORK/remote-b.git
exec git clone $WORK/remote-b.git $WORK/src-b
exec sh -c 'echo b > $WORK/src-b/README.md'
exec sh -c 'cd $WORK/src-b && git add README.md && git commit -m init && git branch -M main && git push origin main'

exec git init --bare -b main $WORK/remote-c.git
exec git clone $WORK/remote-c.git $WORK/src-c
exec sh -c 'echo c > $WORK/src-c/README.md'
exec sh -c 'cd $WORK/src-c && git add README.md && git commit -m init && git branch -M main && git push origin main'

# Three devices sharing one file-backed hub.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB init
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC init

# Device A has an initial valid project and publishes the encrypted history.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/initial $WORK/remote-a.git
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'pushed 1'

# Enroll and approve B and C on A using their actual generated device IDs, so
# A can verify their later signed events.
exec sh -c 'B_ID=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices list | awk "NR==1{print \$1}"); REC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); SIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$B_ID" --name b --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve'
stdout 'enrolled as approved'
exec sh -c 'C_ID=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices list | awk "NR==1{print \$1}"); REC=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices recipient); SIG=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices recipient --signing); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$C_ID" --name c --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve'
stdout 'enrolled as approved'

# A publishes WCK grants; B and C ingest them so both can push encrypted events.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC sync --hub-file=$WORK/hub.json

# A revokes C and publishes the rotated epoch grant for remaining approved
# devices. B syncs so its later valid event encrypts under the current epoch.
exec sh -c 'C_ID=$(devstrap --home=$WORK/homeC --root=$WORK/CodeC devices list | awk "NR==1{print \$1}"); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices revoke "$C_ID"'
stdout 'marked revoked'
stderr 'Rotated workspace key'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json

# B pushes a valid project. C, now revoked on A, still pushes a signed project
# event under its old held epoch key.
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB add --path work/valid-b $WORK/remote-b.git
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json --namespace-only
stdout 'pushed 1'

exec devstrap --home=$WORK/homeC --root=$WORK/CodeC add --path work/revoked-c $WORK/remote-c.git
exec devstrap --home=$WORK/homeC --root=$WORK/CodeC sync --hub-file=$WORK/hub.json --namespace-only
stdout 'pushed 1'

# A syncs both events. The revoked C event must not abort the batch; B's valid
# event applies and materializes, and C's event is visible as an open conflict.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'Synced events'
exec sh -c 'test -d $WORK/CodeA/work/valid-b/.git'
! exec sh -c 'test -d $WORK/CodeA/work/revoked-c/.git'

exec devstrap --home=$WORK/homeA --root=$WORK/CodeA conflicts list
stdout 'event_verification_failure'
stdout 'work/revoked-c'
