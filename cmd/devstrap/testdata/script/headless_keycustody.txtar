# XP-03: headless key custody with DEVSTRAP_NO_KEYCHAIN forces the file-backed
# key store, so init + env capture + env hydrate work without an OS keychain
# (Linux Secret Service absent, CI, headless hosts).

env DEVSTRAP_HOME=$WORK/home
env DEVSTRAP_ROOT=$WORK/Code
env DEVSTRAP_NO_KEYCHAIN=1

# Set up a bare git remote with one commit so `add` can reference a valid remote.
exec git init --bare $WORK/remote.git
exec git clone $WORK/remote.git $WORK/src
exec sh -c 'echo hello > $WORK/src/README.md'
exec sh -c 'cd $WORK/src && git add README.md && git commit -m init && git branch -M main && git push origin main'

exec devstrap init $WORK/Code

# Add the project (creates a skeleton), then hydrate it (blobless clone).
exec devstrap add --path work/proj $WORK/remote.git
exec devstrap hydrate work/proj

# Write an env file inside the cloned project and capture it.
exec sh -c 'echo "API_KEY=secret123" > $WORK/Code/work/proj/.env'
exec devstrap env capture work/proj .env
stdout 'Captured'

# The captured env blob must be a 0600 age file under the home blobs dir.
exec sh -c 'ls $WORK/home/blobs/*.age'

# Hydrate decrypts the blob using the file-backed device identity.
exec devstrap env hydrate work/proj --write .env.local
stdout 'Hydrated'
exec sh -c 'grep secret123 $WORK/Code/work/proj/.env.local'

# The device identity keys must be in the file store (0600), not the keychain.
exec sh -c 'ls $WORK/home/keys/*.agekey'
