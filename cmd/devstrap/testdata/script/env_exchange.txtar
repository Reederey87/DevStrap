# ENV-SYNC-01: captured env profiles sync cross-device through
# env.profile.updated plus the encrypted blob plane. Device B is enrolled before
# capture so A encrypts the env blob to B's age recipient.

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# Set up a bare git remote with one commit.
exec git init --bare -b main $WORK/remote.git
exec git clone $WORK/remote.git $WORK/src
exec sh -c 'echo hello > $WORK/src/README.md'
exec sh -c 'cd $WORK/src && git add README.md && git commit -m init && git branch -M main && git push origin main'

# Device A: founder.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init

# Device B: join A's workspace and enroll both directions.
exec sh -c 'WS=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --workspace-id); devstrap --home=$WORK/homeB --root=$WORK/CodeB init --join --workspace-id "$WS"'
exec sh -c 'A_ID=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices list | awk "NR==1{print \$1}"); AREC=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient); ASIG=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --signing); AFP=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --fingerprint); devstrap --home=$WORK/homeB --root=$WORK/CodeB devices enroll "$A_ID" --name a --os linux --arch arm64 --age-recipient "$AREC" --signing-public-key "$ASIG" --approve --fingerprint "$AFP"'
exec sh -c 'B_ID=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices list | awk "NR==1{print \$1}"); BREC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); BSIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); BFP=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --fingerprint); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$B_ID" --name b --os linux --arch arm64 --age-recipient "$BREC" --signing-public-key "$BSIG" --approve --fingerprint "$BFP"'

# Device A: add a project, capture env, and sync event+blob to the hub.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/env-proj $WORK/remote.git
exec mkdir -p $WORK/CodeA/work/env-proj
exec sh -c 'printf "API_TOKEN=env-sync-marker\nDB_URL=postgres://env-sync\n" > $WORK/CodeA/work/env-proj/.env'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA env capture work/env-proj .env
stdout 'Captured 2 env variables'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json

# Device B: pull the namespace/event/blob planes and hydrate A's captured values.
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB env hydrate work/env-proj --write .env.local
stdout 'Hydrated 2 env variables'
grep env-sync-marker $WORK/CodeB/work/env-proj/.env.local
grep postgres://env-sync $WORK/CodeB/work/env-proj/.env.local

exec devstrap --home=$WORK/homeB --root=$WORK/CodeB conflicts list
stdout 'No open conflicts'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB status
stdout 'Workspace:'
