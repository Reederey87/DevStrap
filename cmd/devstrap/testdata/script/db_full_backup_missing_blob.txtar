# P7-DATA-03: a referenced blob whose ciphertext is gone makes
# `db backup --full` fail fatally — no archive is left behind.

env DEVSTRAP_HOME=$WORK/home
env DEVSTRAP_ROOT=$WORK/Code
env DEVSTRAP_NO_KEYCHAIN=1

env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

exec git init --bare -b main $WORK/remote.git
exec git clone $WORK/remote.git $WORK/src
exec sh -c 'echo hello > $WORK/src/README.md'
exec sh -c 'cd $WORK/src && git add README.md && git commit -m init && git branch -M main && git push origin main'

exec devstrap init $WORK/Code
exec devstrap add --path work/proj $WORK/remote.git
exec devstrap hydrate work/proj

exec sh -c 'echo "API_KEY=missing-blob-secret" > $WORK/Code/work/proj/.env'
exec devstrap env capture work/proj .env
stdout 'Captured'

# Delete every referenced ciphertext so the full backup must refuse.
exec sh -c 'rm -f $WORK/home/blobs/*.age'

! exec devstrap db backup --full $WORK/out.tar
stderr 'referenced secret ciphertext is missing on disk'
! exists $WORK/out.tar
