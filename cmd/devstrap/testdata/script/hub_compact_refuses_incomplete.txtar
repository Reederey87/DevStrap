# P4-HUB-11: `hub compact` shares `hub gc`'s refuse-on-incomplete-view gate — it
# must never advance floors or delete events from a partial replica. Here the hub
# "downgrades" a sealed carrier to plaintext (a downgrade attempt); the pull
# drops it and records a durable skip, which makes compact refuse and leaves the
# event log intact (nothing published, nothing deleted).

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

exec git init --bare -b main $WORK/remoteA.git
exec git clone $WORK/remoteA.git $WORK/srcA
exec sh -c 'echo hello-a > $WORK/srcA/README.md'
exec sh -c 'cd $WORK/srcA && git add README.md && git commit -m init && git branch -M main && git push origin main'

exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/a-proj $WORK/remoteA.git
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'pushed 1'

# Downgrade the one enc.v2 carrier to a plaintext type (grants ride plaintext by
# design, so there is exactly one enc.v2 object).
exec sh -c 'sed "s/\"Type\": \"enc.v2\"/\"Type\": \"project.added\"/" $WORK/hub.json > $WORK/hub2.json && mv $WORK/hub2.json $WORK/hub.json'

# The pull drops it (anti-downgrade) and records a durable skip; the sync itself
# still completes.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA status
stdout 'Skipped hub events: 1'

# hub compact refuses while the device cannot consume the full log, and writes
# nothing: no retention manifest and no snapshot object appear.
! exec devstrap --home=$WORK/homeA --root=$WORK/CodeA hub compact --hub-file=$WORK/hub.json
stderr 'refus'
! exec test -f $WORK/hub-meta/retention.json
! exec sh -c 'ls $WORK/hub-snapshots/*.json'

# The downgraded event object is still on the hub — compaction deleted nothing.
exec grep 'project.added' $WORK/hub.json
