# P7-WIP invariant guard (non-negotiable — spec/07 § Working-state plane;
# docs/audits/AUDIT_RECOMMENDATIONS_2026-06-27.md "INVARIANT INTERLOCK"): the
# fresh-worktree resolver must base ONLY off origin/<default_branch>, and must
# NEVER read refs/devstrap/wip/* — even when a WIP ref for the SAME project
# already sits in the SAME local repo (exactly what an earlier `wip fetch`
# leaves behind). Device A pushes WIP content carrying a unique marker; device
# B mirrors A's WIP ref locally via `wip fetch`, THEN creates a fresh worktree
# for that same project. The new worktree must never see the marker, must
# base off the real default branch, and must record a base SHA distinct from
# the WIP push — and the WIP ref itself must survive untouched, proving
# worktree creation never needed to read it at all.

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

# Bare remote with one commit, shared by both devices.
exec git init --bare -b main $WORK/remote.git
exec git clone $WORK/remote.git $WORK/src
exec sh -c 'echo hello > $WORK/src/README.md'
exec sh -c 'cd $WORK/src && git add README.md && git commit -m init && git branch -M main && git push origin main'

# Device A: init, add the project, sync (materializes a real clone).
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/proj $WORK/remote.git
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'pushed 1'

# Device B: init, enroll+approve (so it can decrypt A's events), sync
# (materializes its own clone of the same project).
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB init
exec sh -c 'REC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); SIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); FP=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --fingerprint); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll dev_b --name b --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve --fingerprint "$FP"'
stdout 'enrolled as approved'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
stdout 'materialized'

# Device A: make an uncommitted change carrying a unique marker and push its
# WIP ref. --json surfaces the full (unshortened) sha so we can later prove
# the fresh worktree's base sha is NOT this one.
exec sh -c 'echo SECRET_WIP_MARKER_DO_NOT_LEAK >> $WORK/CodeA/work/proj/README.md'
exec sh -c 'devstrap --home=$WORK/homeA --root=$WORK/CodeA --json wip push work/proj > $WORK/push.json'
exec sh -c 'sed -n "s/.*\"sha\": \"\\([^\"]*\\)\".*/\\1/p" $WORK/push.json > $WORK/wip-sha.txt'
exec sh -c 'test -s $WORK/wip-sha.txt'
exec sh -c 'sed -n "s/.*\"ref\": \"\\([^\"]*\\)\".*/\\1/p" $WORK/push.json > $WORK/wip-ref.txt'
exec sh -c 'test -s $WORK/wip-ref.txt'

# Publish the repo.wip.pushed event, then have B pull it and `wip fetch` A's
# ref into its OWN local repo — the WIP ref now genuinely exists as a local
# ref in the SAME repo that will host the fresh worktree, not merely absent
# because nobody happened to fetch it.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'pushed 1'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
stdout 'pulled 1'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB wip fetch work/proj
stdout 'Fetched refs/devstrap/wip/'
exec sh -c 'git -C $WORK/CodeB/work/proj show-ref --verify --quiet "$(cat $WORK/wip-ref.txt)"'

# Device B: create a FRESH worktree for the SAME project that now has A's WIP
# ref sitting locally. This is the adversarial precondition the invariant must
# survive.
exec sh -c 'devstrap --home=$WORK/homeB --root=$WORK/CodeB worktree new work/proj --fresh-upstream --name invariant-check > $WORK/worktree.out'
exec grep 'Created worktree' $WORK/worktree.out
exec grep 'from origin/main ' $WORK/worktree.out
exec sh -c 'sed -n "s#Created worktree [^ ]* at \\([^ ]*\\) from.*#\\1#p" $WORK/worktree.out > $WORK/wt-path.txt'
exec sh -c 'sed -n "s#.* from [^ ]* \\([0-9a-f]*\\)\$#\\1#p" $WORK/worktree.out > $WORK/base-sha.txt'
exec sh -c 'test -s $WORK/wt-path.txt'
exec sh -c 'test -s $WORK/base-sha.txt'

# The new worktree's checked-out content does NOT contain the WIP marker.
exec sh -c '! grep -q SECRET_WIP_MARKER_DO_NOT_LEAK "$(cat $WORK/wt-path.txt)/README.md"'

# The recorded base sha is NOT the WIP push's sha.
exec sh -c 'if [ "$(cat $WORK/wip-sha.txt)" = "$(cat $WORK/base-sha.txt)" ]; then echo "REGRESSION: worktree based off the WIP push sha" >&2; exit 1; fi'

# The WIP ref itself is untouched — worktree creation never needed to read,
# delete, or move it; it simply never looked at it.
exec sh -c 'git -C $WORK/CodeB/work/proj show-ref --verify --quiet "$(cat $WORK/wip-ref.txt)"'
