# P4-SEC-07 periodic rotation: an age-triggered rotation during `sync` mints
# epoch+1 AFTER the pull and BEFORE the push, so the grant events AND data
# sealed under the new epoch ride the SAME push — and the peer converges in a
# single pull (grant ingested first, then the epoch-2 event decrypts).

env DEVSTRAP_NO_KEYCHAIN=1
env GIT_AUTHOR_NAME=devstrap-test
env GIT_AUTHOR_EMAIL=test@example.com
env GIT_COMMITTER_NAME=devstrap-test
env GIT_COMMITTER_EMAIL=test@example.com

exec git init --bare -b main $WORK/remoteA.git
exec git clone $WORK/remoteA.git $WORK/srcA
exec sh -c 'echo hello-a > $WORK/srcA/README.md'
exec sh -c 'cd $WORK/srcA && git add README.md && git commit -m init && git branch -M main && git push origin main'
exec git init --bare -b main $WORK/remoteA2.git
exec git clone $WORK/remoteA2.git $WORK/srcA2
exec sh -c 'echo hello-a2 > $WORK/srcA2/README.md'
exec sh -c 'cd $WORK/srcA2 && git add README.md && git commit -m init && git branch -M main && git push origin main'

# A founds epoch 1; B joins, pins A, gets approved; both converge on epoch 1.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA init
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/a-proj $WORK/remoteA.git
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stdout 'pushed 1'
exec sh -c 'WS=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --workspace-id); devstrap --home=$WORK/homeB --root=$WORK/CodeB init --join --workspace-id "$WS"'
exec sh -c 'A_ID=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices list | awk "NR==1{print \$1}"); AREC=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient); ASIG=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --signing); AFP=$(devstrap --home=$WORK/homeA --root=$WORK/CodeA devices recipient --fingerprint); devstrap --home=$WORK/homeB --root=$WORK/CodeB devices enroll "$A_ID" --name a --os linux --arch arm64 --age-recipient "$AREC" --signing-public-key "$ASIG" --approve --fingerprint "$AFP"'
exec sh -c 'B_ID=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices list | awk "NR==1{print \$1}"); REC=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient); SIG=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --signing); FP=$(devstrap --home=$WORK/homeB --root=$WORK/CodeB devices recipient --fingerprint); devstrap --home=$WORK/homeA --root=$WORK/CodeA devices enroll "$B_ID" --name b --os linux --arch arm64 --age-recipient "$REC" --signing-public-key "$SIG" --approve --fingerprint "$FP"'
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec sh -c 'test -d $WORK/CodeB/work/a-proj/.git'

# A adds a second project and syncs with an expired rotation deadline: the
# cycle rotates to epoch 2 post-pull/pre-push, and the epoch-2 grant plus the
# a2-proj event (sealed under epoch 2) ride the same push.
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA add --path work/a2-proj $WORK/remoteA2.git
env DEVSTRAP_KEYS_ROTATE_MAX_AGE=1ms
exec devstrap --home=$WORK/homeA --root=$WORK/CodeA sync --hub-file=$WORK/hub.json
stderr 'Rotated workspace key to epoch 2'
env DEVSTRAP_KEYS_ROTATE_MAX_AGE=

# B converges in ONE pull: the grant ingests first, then the epoch-2 event
# decrypts and a2-proj materializes. No wedge, no second sync needed.
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB sync --hub-file=$WORK/hub.json
exec sh -c 'test -d $WORK/CodeB/work/a2-proj/.git'
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB conflicts list
stdout 'No open conflicts.'

# Doctor on B: fresh epoch age, nothing awaiting a grant.
exec devstrap --home=$WORK/homeB --root=$WORK/CodeB doctor
stdout 'workspace key age.*epoch 2'
stdout 'awaiting key grants.*0'
